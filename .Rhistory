normalize_gene <- function(x) {
x |>
as.character() |>
trimws()
}
read_table_auto <- function(path, sheet = 1) {
ext <- tolower(tools::file_ext(path))
if (ext %in% c("xlsx", "xls")) {
df <- readxl::read_excel(path, sheet = sheet)
} else if (ext == "csv") {
df <- readr::read_csv(path, show_col_types = FALSE)
} else if (ext %in% c("tsv", "txt")) {
df <- readr::read_tsv(path, show_col_types = FALSE)
} else {
stop("Unsupported file type: ", path)
}
as_tibble(df)
}
extract_group_tbl <- function(path) {
df <- read_table_auto(path)
if (ncol(df) < 1) {
stop("Group file has no columns: ", basename(path))
}
gene_vec <- df[[1]] |> normalize_gene()
col_lc <- tolower(names(df))
group_col_candidates <- names(df)[col_lc %in% c("group", "groups", "cluster", "clusters", "class", "category")]
if (length(group_col_candidates) >= 1) {
group_vec <- df[[group_col_candidates[1]]] |> as.character() |> trimws()
} else if (ncol(df) >= 2 && any(!is.na(df[[2]]) & trimws(as.character(df[[2]])) != "")) {
group_vec <- df[[2]] |> as.character() |> trimws()
} else {
group_vec <- rep(tools::file_path_sans_ext(basename(path)), nrow(df))
}
tibble(
gene = gene_vec,
group = group_vec,
source_file = basename(path)
) |>
filter(!is.na(gene), gene != "") |>
mutate(
group = ifelse(is.na(group) | group == "", tools::file_path_sans_ext(source_file), group),
gene_key = normalize_gene(gene)
) |>
distinct(gene_key, group, .keep_all = TRUE)
}
calc_box_stats <- function(x) {
x <- as.numeric(x)
x <- x[is.finite(x)]
if (length(x) == 0) {
return(tibble(
n_genes = 0,
min = NA_real_,
percentile_05 = NA_real_,
q1 = NA_real_,
median = NA_real_,
q3 = NA_real_,
percentile_95 = NA_real_,
iqr = NA_real_,
lower_whisker = NA_real_,
upper_whisker = NA_real_,
max = NA_real_,
outlier_n = NA_integer_
))
}
bp <- boxplot.stats(x)
tibble(
n_genes = length(x),
min = min(x, na.rm = TRUE),
percentile_05 = as.numeric(stats::quantile(x, 0.05, na.rm = TRUE, type = 7)),
q1 = as.numeric(stats::quantile(x, 0.25, na.rm = TRUE, type = 7)),
median = stats::median(x, na.rm = TRUE),
q3 = as.numeric(stats::quantile(x, 0.75, na.rm = TRUE, type = 7)),
percentile_95 = as.numeric(stats::quantile(x, 0.95, na.rm = TRUE, type = 7)),
iqr = stats::IQR(x, na.rm = TRUE),
lower_whisker = bp$stats[1],
upper_whisker = bp$stats[5],
max = max(x, na.rm = TRUE),
outlier_n = length(bp$out)
)
}
