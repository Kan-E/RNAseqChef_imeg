calc_box_stats <- function(x) {
x <- as.numeric(x)
x <- x[is.finite(x)]
if (length(x) == 0) {
return(tibble(
n_genes = 0,
min = NA_real_,
percentile_05 = NA_real_,
q1 = NA_real_,
median = NA_real_,
q3 = NA_real_,
percentile_95 = NA_real_,
iqr = NA_real_,
lower_whisker = NA_real_,
upper_whisker = NA_real_,
max = NA_real_,
outlier_n = NA_integer_
))
}
bp <- boxplot.stats(x)
tibble(
n_genes = length(x),
min = min(x, na.rm = TRUE),
percentile_05 = as.numeric(stats::quantile(x, 0.05, na.rm = TRUE, type = 7)),
q1 = as.numeric(stats::quantile(x, 0.25, na.rm = TRUE, type = 7)),
median = stats::median(x, na.rm = TRUE),
q3 = as.numeric(stats::quantile(x, 0.75, na.rm = TRUE, type = 7)),
percentile_95 = as.numeric(stats::quantile(x, 0.95, na.rm = TRUE, type = 7)),
iqr = stats::IQR(x, na.rm = TRUE),
lower_whisker = bp$stats[1],
upper_whisker = bp$stats[5],
max = max(x, na.rm = TRUE),
outlier_n = length(bp$out)
)
}
count_df <- read_table_auto(count_file, sheet = count_sheet)
if (!(count_gene_col %in% names(count_df))) {
stop("指定した遺伝子列がカウントデータ内に見つかりません: ", count_gene_col)
}
count_df <- count_df |>
mutate(gene_key = normalize_gene(.data[[count_gene_col]]))
knitr::kable(head(count_df, 5), caption = "カウントデータ先頭")
group_files <- list.files(
path = group_dir,
pattern = group_pattern,
full.names = TRUE,
ignore.case = TRUE
)
group_files <- group_files[normalizePath(group_files) != normalizePath(count_file)]
if (length(group_files) == 0) {
stop(
"グループファイルが見つかりませんでした。\n",
"group_dir または group_pattern を確認してください。\n",
"現在の pattern: ", group_pattern
)
}
group_file_tbl <- tibble(
file = basename(group_files),
path = group_files
)
knitr::kable(group_file_tbl, caption = "使用するグループファイル")
group_membership <- purrr::map_dfr(group_files, extract_group_tbl) |>
distinct(gene_key, group, .keep_all = TRUE)
knitr::kable(head(group_membership, 10), caption = "グループ対応表（先頭）")
group_lookup <- group_membership |>
group_by(gene_key) |>
summarise(
Group = paste(sort(unique(group)), collapse = ";"),
n_groups = dplyr::n_distinct(group),
.groups = "drop"
)
annotated_count <- count_df |>
left_join(group_lookup, by = "gene_key") |>
mutate(
Group = ifelse(is.na(Group), "Unassigned", Group),
n_groups = ifelse(is.na(n_groups), 0L, n_groups)
)
annotated_count <- annotated_count |>
relocate(Group, n_groups, .after = all_of(count_gene_col))
knitr::kable(head(annotated_count, 10), caption = "Group列付加後（先頭）")
non_sample_cols <- unique(c(count_gene_col, "gene_key", "Group", "n_groups"))
sample_cols <- setdiff(names(annotated_count), non_sample_cols)
sample_cols <- sample_cols[vapply(annotated_count[sample_cols], is.numeric, logical(1))]
if (length(sample_cols) == 0) {
stop("数値のサンプル列が見つかりませんでした。")
}
tibble(sample_cols = sample_cols) |>
knitr::kable(caption = "集計対象サンプル列")
expr_long <- annotated_count |>
select(all_of(count_gene_col), gene_key, all_of(sample_cols)) |>
inner_join(group_membership |> select(gene_key, group), by = "gene_key") |>
pivot_longer(
cols = all_of(sample_cols),
names_to = "Sample",
values_to = "Value"
)
summary_long <- expr_long |>
group_by(group, Sample) |>
group_modify(~ calc_box_stats(.x$Value)) |>
ungroup() |>
rename(Group = group) |>
arrange(Group, Sample)
summary_wide <- summary_long |>
pivot_wider(
names_from = Sample,
values_from = c(
n_genes, min, percentile_05, q1, median, q3,
percentile_95, iqr, lower_whisker, upper_whisker,
max, outlier_n
),
names_sep = "__"
)
knitr::kable(head(summary_long, 20), caption = "統計量テーブル（long形式、先頭20行）")
out_dir <- dirname(normalizePath(count_file))
xlsx_out <- file.path(out_dir, paste0(output_prefix, ".xlsx"))
csv_out  <- file.path(out_dir, paste0(output_prefix, "_summary_long.csv"))
export_list <- list(
group_files_used = group_file_tbl,
group_membership = group_membership |>
select(gene, group, source_file),
annotated_count = annotated_count |>
select(-gene_key),
summary_long = summary_long,
summary_wide = summary_wide
)
openxlsx::write.xlsx(
x = export_list,
file = xlsx_out,
asTable = TRUE,
overwrite = TRUE
)
readr::write_csv(summary_long, csv_out)
cat("Excel output : ", xlsx_out, "\n")
cat("CSV output   : ", csv_out, "\n")
